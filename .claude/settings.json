{
    "hooks": {
        "PostToolUse": [
            {
                "matcher": "Write|Edit",
                "hooks": [
                    {
                        "type": "command",
                        "command": "jq -r '.tool_input.file_path' | xargs biome format --write",
                        "timeout": 30
                    }
                ]
            }
        ]
    }
}
